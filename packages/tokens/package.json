{
  "name": "@w5-ui/tokens",
  "version": "0.5.0",
  "description": "Design tokens (CSS variables for dark + light motifs and a JS token map) for the Dash UI design system, by Webber's design systems.",
  "keywords": [
    "design-tokens",
    "css-variables",
    "design-system",
    "dashboard",
    "dash-ui"
  ],
  "author": "Webber Takken (https://github.com/webbertakken)",
  "license": "MIT",
  "homepage": "https://github.com/webbertakken/dash-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webbertakken/dash-ui.git",
    "directory": "packages/tokens"
  },
  "bugs": "https://github.com/webbertakken/dash-ui/issues",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./src/tokens.ts",
  "types": "./src/tokens.ts",
  "exports": {
    ".": "./src/tokens.ts",
    "./css": "./src/tokens.css",
    "./tokens.css": "./src/tokens.css",
    "./tailwind.css": "./src/tailwind.css",
    "./tailwind-full.css": "./src/tailwind-full.css",
    "./dashboard.css": "./src/dashboard.css"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "yarn run -T tsgo --noEmit"
  }
}
