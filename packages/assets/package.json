{
  "name": "@w5-ui/assets",
  "version": "0.2.0",
  "description": "Brand assets (mark, wordmark, app-rail icons) for the Dash UI design system, by Webber's design systems.",
  "keywords": [
    "svg",
    "logos",
    "assets",
    "design-system",
    "dash-ui"
  ],
  "author": "Webber Takken (https://github.com/webbertakken)",
  "license": "MIT",
  "homepage": "https://github.com/webbertakken/dash-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webbertakken/dash-ui.git",
    "directory": "packages/assets"
  },
  "bugs": "https://github.com/webbertakken/dash-ui/issues",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./logos/*": "./logos/*"
  },
  "files": [
    "src",
    "logos"
  ],
  "scripts": {
    "typecheck": "yarn run -T tsgo --noEmit"
  }
}
