{
  "name": "@w5-ui/wc",
  "version": "0.4.0",
  "description": "Framework-agnostic web components for the Dash UI design system - ~165 custom elements (dash-*) compiled from @w5-ui/svelte. Use in any framework or vanilla HTML. Part of Webber's design systems.",
  "keywords": [
    "web-components",
    "custom-elements",
    "design-system",
    "dashboard",
    "ui-library",
    "dash-ui"
  ],
  "author": "Webber Takken (https://github.com/webbertakken)",
  "license": "MIT",
  "homepage": "https://github.com/webbertakken/dash-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webbertakken/dash-ui.git",
    "directory": "packages/wc"
  },
  "bugs": "https://github.com/webbertakken/dash-ui/issues",
  "type": "module",
  "sideEffects": true,
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css",
    "./register": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx ./scripts/generate-wrappers.ts",
    "build": "yarn generate && vite build",
    "dev": "vite build --watch",
    "typecheck": "echo skip",
    "prepublishOnly": "yarn build"
  },
  "dependencies": {
    "@w5-ui/assets": "workspace:*",
    "@w5-ui/svelte": "workspace:*",
    "@w5-ui/tokens": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "svelte": "^5.55.8",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
