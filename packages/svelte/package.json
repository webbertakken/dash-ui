{
  "name": "@dash-ui/svelte",
  "version": "0.1.0",
  "description": "Svelte 4 components for the Dash UI design system - mirrors the @dash-ui/react API 1:1. Part of Webber's design systems.",
  "keywords": [
    "svelte",
    "components",
    "design-system",
    "dashboard",
    "ui-library",
    "dash-ui"
  ],
  "author": "Webber Takken (https://github.com/webbertakken)",
  "license": "MIT",
  "homepage": "https://github.com/webbertakken/dash-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webbertakken/dash-ui.git",
    "directory": "packages/svelte"
  },
  "bugs": "https://github.com/webbertakken/dash-ui/issues",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "main": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "svelte": "./src/lib/index.ts",
      "types": "./src/lib/index.ts",
      "default": "./src/lib/index.ts"
    },
    "./styles.css": "./src/lib/styles.css",
    "./components/*.svelte": "./src/lib/components/*.svelte"
  },
  "peerDependencies": {
    "svelte": ">=4"
  },
  "dependencies": {
    "@dash-ui/assets": "workspace:*",
    "@dash-ui/tokens": "workspace:*"
  },
  "devDependencies": {
    "svelte": "^4.2.19",
    "typescript": "^5.5.0"
  },
  "files": [
    "src"
  ]
}
