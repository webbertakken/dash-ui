{
  "name": "dashboard-svelte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./pages/*.svelte": "./src/pages/*.svelte",
    "./App.svelte": "./src/App.svelte"
  },
  "scripts": {
    "dev": "vite --port 5174 --host",
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "preview": "vite preview --port 5174",
    "pw": "playwright test",
    "pw:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@w5-ui/assets": "workspace:*",
    "@w5-ui/svelte": "workspace:*",
    "@w5-ui/tokens": "workspace:*",
    "svelte": "^5.55.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "@tsconfig/svelte": "^5.0.0",
    "pngjs": "^7.0.0",
    "svelte-check": "^4.3.4",
    "svelte-preprocess": "^6.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  }
}
